#!/usr/bin/env bash
set -euo pipefail

ERROR_MESSAGE='🔨❌ You need to fix a few things in your code.
        Please review the above errors...'

# Print the error banner and exit non-zero. Used after every check that
# must block the commit on failure.
fail() {
    echo "$ERROR_MESSAGE"
    exit 1
}

# Skip the heavy checks (tsc + tests + build) with: SKIP_CHECKS=1 git commit -m "..."
# Useful when committing intentionally broken/in-progress state (e.g. TDD red phase
# or a WIP checkpoint). Lint, style, Trivy, and lint-probe still run.
if [ "${SKIP_CHECKS:-}" = "1" ]; then
    echo '⏭️  SKIP_CHECKS=1 detected — skipping tsc, tests, and build (lint/style checks still run)'
fi

echo '🏗️👷 Pre commit checks being completed...'

# ── Secret scanning ────────────────────────────────────────────────────────
# Scans staged files only - fast and low CPU. Uses .gitleaks.toml for
# allowlists and .gitleaksignore for one-off historical fingerprints.
# Install: brew install gitleaks
if ! command -v gitleaks &>/dev/null; then
    echo ''
    echo '🔑❌ gitleaks is not installed - install it before committing.'
    echo ''
    echo '   Fix: brew install gitleaks'
    echo ''
    exit 1
fi

echo '🔑 Running gitleaks secret scan...'
if ! gitleaks protect --staged --no-banner; then
    echo '❌ Potential secret detected! Review the above findings.'
    echo '   If this is a false positive, add an allowlist entry to .gitleaks.toml'
    exit 1
fi
echo '✅ No secrets detected!'

# ── Deps sync check ────────────────────────────────────────────────────────
# Run this FIRST before any pnpm command. If node_modules is out of sync
# with package.json, pnpm will abort with a cryptic no-TTY error on every
# subsequent command. Catch it here with a clear fix instruction instead.
if ! pnpm install --frozen-lockfile --silent 2>/dev/null; then
    echo ''
    echo '📦❌ node_modules is out of sync with package.json / pnpm-lock.yaml.'
    echo ''
    echo '   Fix: run `pnpm install` then try committing again.'
    echo ''
    exit 1
fi

# Function to check if files matching a pattern have changed
files_changed() {
    git diff --cached --name-only | grep -E "$1"
}

# Run Trivy only when dependency manifests changed
if git diff --cached --name-only | grep -qE '^(package\.json|pnpm-lock\.yaml)$'; then
    echo "🔐 Running Trivy security scan..."
    if ! trivy fs --scanners vuln --ignore-unfixed --detection-priority comprehensive --disable-telemetry --skip-version-check --severity HIGH,CRITICAL --exit-code 1 .; then
        echo "❌ Security vulnerabilities found! Fix them before committing."
        exit 1
    fi
    echo "✅ No critical vulnerabilities found!"
else
    echo "🔐 Skipping Trivy (package.json / pnpm-lock.yaml unchanged)"
fi

# Run ESLint config probes only when the config itself changed.
# Cheap (~30s cold, skipped otherwise) but catches the case where a plugin
# upgrade or config tweak silently disables a rule we depend on.
if git diff --cached --name-only | grep -qE '^eslint\.config\.ts$'; then
    echo "🧪 eslint.config.ts changed — running lint probes..."
    pnpm lint:probe || fail
else
    echo "🧪 Skipping lint probes (eslint.config.ts unchanged)"
fi

echo '📝 Running style and linting checks...'
pnpm exec lint-staged || fail

# Heavy checks — type-check, run tests, then build.
# Skipped entirely when SKIP_CHECKS=1, and short-circuited when no
# TS/config files changed (cuts ~no-op commits like docs / .md edits).
if [ "${SKIP_CHECKS:-}" = "1" ]; then
    echo '⏭️  Skipping tsc, tests, and build step.'
elif files_changed '\.(ts|tsx)$|^tsconfig\.json$|^package\.json$' > /dev/null; then
    echo '🔬 Type-checking project (tsc --noEmit)...'
    pnpm typecheck || fail

    echo '💪 Relevant files changed. Running tests...'
    pnpm test || fail

    echo '👍 Code looks good so far... running build after successful tests!'
    pnpm build || fail
elif files_changed '\.mjs$|\.cjs$|^next\.config\.' > /dev/null; then
    echo '📋 Config files changed. Running build...'
    pnpm build || fail
else
    echo '🏎️ No relevant files changed. Skipping tsc, tests, and build step.'
fi

echo '✅ All good to go, making the commit now!'
