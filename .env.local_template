# Clerk authentication keys (https://dashboard.clerk.com -> API Keys).
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# Postgres connection string.
# Local dev: matches the docker-compose.yml Postgres service.
# Production: replace with your hosted provider's URL (e.g. Neon).
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/app

# Docs site URL. When set, a "Docs" link appears in the homepage header.
# Local dev: the docs site runs on :3001 via `pnpm dev:docs` or `pnpm dev:all`.
# Production: point this at your deployed docs subdomain (e.g. https://docs.myapp.com).
NEXT_PUBLIC_DOCS_URL=http://localhost:3001

# Logging (both optional).
# LOG_LEVEL: winston verbosity floor. Defaults per env (info/debug/warn) when
# unset; set to override for a run, e.g. LOG_LEVEL=debug.
# LOG_LEVEL=

# DB_QUERY_LOG: set to 1 to stream raw Drizzle SQL + params to the console while
# building. Off by default — it's a noisy dev-only diagnostic.
# DB_QUERY_LOG=

# OpenTelemetry (optional — traces only, no effect when unset).
# OTEL_EXPORTER_OTLP_ENDPOINT: collector endpoint. For local dev use the below
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318

# NEXT_OTEL_VERBOSE: set to 1 to surface additional internal Next.js spans
# (render lifecycle, segment resolution). Useful when debugging instrumentation.
# NEXT_OTEL_VERBOSE=1

# E2E test credentials (Playwright + Clerk).
# E2E_CLERK_USER_EMAIL: email of a user that exists in your Clerk dashboard.
# E2E_CLERK_USER_EMAIL=
