{
  "name": "next-template",
  "version": "0.1.0",
  "private": true,
  "scarfSettings": {
    "enabled": false
  },
  "scripts": {
    "docs:assets": "tsx scripts/copy-swagger-ui.ts",
    "predev": "pnpm docs:assets",
    "dev": "next dev",
    "dev:docs": "pnpm --filter docs dev:port",
    "dev:all": "concurrently --names app,docs --prefix-colors cyan,magenta \"pnpm dev\" \"pnpm dev:docs\"",
    "prebuild": "pnpm docs:assets",
    "build": "next build",
    "build:docs": "pnpm --filter docs build",
    "build:all": "pnpm build && pnpm build:docs",
    "start": "next start",
    "lint": "eslint",
    "lint:probe": "bash scripts/lint-probe.sh",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "e2e": "playwright test -c e2e-tests/playwright.config.ts",
    "e2e:ui": "playwright test -c e2e-tests/playwright.config.ts --ui",
    "e2e:codegen": "playwright codegen http://localhost:3000",
    "e2e:report": "playwright show-report e2e-tests/playwright-report",
    "e2e:debug": "playwright test -c e2e-tests/playwright.config.ts --debug",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx src/db/run-migrations.ts",
    "db:seed": "tsx scripts/seed.ts",
    "db:check": "tsx scripts/db-smoke-check.ts",
    "db:studio": "drizzle-kit studio",
    "prepare": "husky"
  },
  "dependencies": {
    "@clerk/nextjs": "^7.5.2",
    "@hookform/resolvers": "^5.4.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.45.2",
    "lucide-react": "^1.16.0",
    "next": "16.2.6",
    "next-themes": "^0.4.6",
    "pg": "^8.21.0",
    "radix-ui": "^1.4.3",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-hook-form": "^7.80.0",
    "sonner": "^2.0.7",
    "swagger-ui-dist": "^5.32.6",
    "swr": "^2.4.1",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "winston": "^3.19.0",
    "zod": "^4.4.3",
    "zod-openapi": "^5.4.6",
    "zustand": "^5.0.14"
  },
  "engines": {
    "node": ">=24",
    "pnpm": ">=10"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@stylistic/eslint-plugin": "^5.10.0",
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^24",
    "@types/pg": "^8.20.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "concurrently": "^10.0.3",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jsdoc": "^63.0.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-simple-import-sort": "^13.0.0",
    "eslint-plugin-tsdoc": "^0.5.2",
    "husky": "^9.1.7",
    "jiti": "^2.7.0",
    "jsdom": "^29.1.1",
    "lint-staged": "^17.0.5",
    "prettier": "^3.8.3",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "shadcn": "^4.7.0",
    "tailwindcss": "^4",
    "tsx": "^4.22.4",
    "typescript": "^5",
    "vitest": "^4.1.7"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,mjs,cjs}": [
      "eslint --fix --no-warn-ignored",
      "prettier --write"
    ],
    "*.{json,md,mdx,yml,yaml,css}": [
      "prettier --write"
    ]
  }
}
