{
  // ─── EEP Template — Next.js devcontainer ────────────────────────────────────
  // Opens a zero-setup environment in VS Code / Cursor / GitHub Codespaces.
  //
  // What you get:
  //   • Node 24 + pnpm (matches .nvmrc and engines field)
  //   • Python 3.14 + uv + Graphviz  (for regenerating diagrams/)
  //   • Postgres 17 as a sidecar container via Docker Compose
  //   • Zsh + Oh My Zsh with autosuggestions, syntax-highlighting, history-search
  //   • Full VS Code extension set pre-installed
  //
  // First-time setup after the container starts:
  //   1. Copy .env.local_template → .env.local and fill in your Clerk keys.
  //   2. DATABASE_URL is auto-overridden to point at the Postgres sidecar —
  //      no change needed for local dev.
  //   3. Run `pnpm dev` to start the app on :3000.
  //
  // Architecture note — why no dockerComposeFile:
  //   Rancher Desktop runs Docker in a Linux VM and resolves relative paths in
  //   compose files from that VM's CWD, not the host repo root. This causes the
  //   entire repos folder to be mounted instead of just this repo. Using a
  //   single-container devcontainer with an inline Postgres sidecar (via the
  //   ghcr.io/devcontainers/features/postgres feature, or postCreateCommand)
  //   avoids this entirely — the Dev Containers extension always mounts the
  //   correct workspace folder regardless of Docker runtime.
  // ────────────────────────────────────────────────────────────────────────────

  "name": "eep-template-next-app",

  // Single-container mode — no dockerComposeFile. The Dev Containers extension
  // handles the workspace mount correctly on all runtimes (Docker Desktop,
  // Rancher Desktop, Codespaces).
  // Postgres and Graphviz are installed as root in the Dockerfile (avoids sudo
  // password prompts that occur when installing via postCreateCommand).
  "build": { "dockerfile": "Dockerfile" },

  "features": {
    // Node 24 + pnpm via corepack
    "ghcr.io/devcontainers/features/node:1": {
      "version": "24.16.0",
      "pnpmVersion": "latest"
    },
    // Python 3.14 for diagrams/
    "ghcr.io/devcontainers/features/python:1": {
      "version": "3.14"
    },
    // Zsh + Oh My Zsh (terminal UX)
    "ghcr.io/devcontainers/features/common-utils:2": {
      "installZsh": true,
      "installOhMyZsh": true,
      "configureZshAsDefaultShell": true,
      "upgradePackages": true
    }
  },

  // DATABASE_URL for the local Postgres sidecar (localhost inside the container).
  "containerEnv": {
    "DATABASE_URL": "postgresql://postgres:postgres@localhost:5432/app"
  },

  // Runs once when the container is first created.
  "postCreateCommand": "zsh .devcontainer/post-create.sh",

  // Runs every time the container starts.
  "postStartCommand": "bash .devcontainer/post-start.sh",

  "customizations": {
    "vscode": {
      "extensions": [
        // TypeScript / JS
        "dbaeumer.vscode-eslint",
        "esbenp.prettier-vscode",
        // Tailwind
        "bradlc.vscode-tailwindcss",
        // Testing
        "ms-playwright.playwright",
        "vitest.explorer",
        // Git
        "eamodio.gitlens",
        // Python (for diagrams/)
        "ms-python.python",
        "charliermarsh.ruff",
        // Icons + theme
        "pkief.material-icon-theme",
        // Misc DX
        "streetsidesoftware.code-spell-checker",
        "usernamehw.errorlens"
      ],
      "settings": {
        "terminal.integrated.defaultProfile.linux": "zsh",
        "terminal.integrated.profiles.linux": {
          "zsh": {
            "path": "/bin/zsh"
          }
        },
        "editor.formatOnSave": true,
        "editor.defaultFormatter": "esbenp.prettier-vscode",
        "[typescript]": {
          "editor.defaultFormatter": "esbenp.prettier-vscode"
        },
        "[typescriptreact]": {
          "editor.defaultFormatter": "esbenp.prettier-vscode"
        }
      }
    }
  },

  "remoteUser": "vscode"
}
